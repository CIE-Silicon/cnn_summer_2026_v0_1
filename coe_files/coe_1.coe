; ===========================================================================
;  cnn_bram.coe
;
;  Vivado Block Memory Generator (blk_mem_gen) initialisation file.
;
;  Memory configuration assumed
;  ----------------------------
;  Width      : 32 bits
;  Depth      : 4096 (12-bit address)
;  Port type  : Single-port ROM/RAM
;  Output reg : 1 pipeline stage (add one WAIT state in FSMs)
;
;  Address map
;  -----------
;  0x000 – 0x03F  Image pixel data  (8 rows × 8 words/row = 64 words)
;                 Each 32-bit word packs 4 consecutive pixels (LSByte first).
;                 Row k starts at address k*8.
;
;  0x100 – 0x111  Weight nibble data (16 filters × 9 nibbles = 144 nibbles
;                 = 18 × 32-bit words packed 8 nibbles/word, LSNibble first).
;
;  0x112 – 0xFFF  Reserved (zeros)
;
;  How to use in Vivado
;  --------------------
;  1. Open Block Memory Generator IP ? "Other Options" tab.
;  2. Tick "Load Init File" and browse to this .coe file.
;  3. Set Memory Type to "Single Port RAM" (or ROM if read-only).
;  4. Set Port A Width = 32, Depth = 4096.
;  5. Enable Output Register (1 stage) ? match the WAIT states in the FSMs.
;  6. Generate.
;
;  Regenerating this file
;  ----------------------
;  Row pixel pattern  : row k, pixel p = (k*32 + p) & 0xFF (wraps to 8-bit)
;  Weight pattern     : filter f, weight w ? nibble = (f*9 + w) & 0xF
;                       8 nibbles packed per 32-bit word, nibble 0 in bits[3:0]
; ===========================================================================

memory_initialization_radix  = 16;
memory_initialization_vector  =

